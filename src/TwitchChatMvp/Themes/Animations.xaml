<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:services="clr-namespace:TwitchChatMvp.Services">
    <Duration x:Key="MotionFastDuration">0:0:0.12</Duration>
    <Duration x:Key="MotionNormalDuration">0:0:0.18</Duration>
    <Duration x:Key="MotionSlowDuration">0:0:0.22</Duration>

    <CubicEase x:Key="MotionEaseOut" EasingMode="EaseOut" />

    <Style x:Key="AnimatedButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="services:AnimationService.EnableButtonAnimations" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>

    <Style x:Key="AnimatedIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="services:AnimationService.EnableButtonAnimations" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>

    <Style x:Key="AnimatedPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource GlassCardStyle}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>

    <Style x:Key="AnimatedListItemStyle" TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
    </Style>
</ResourceDictionary>
