<Window x:Class="TwitchChatMvp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:TwitchChatMvp.Behaviors"
        xmlns:controls="clr-namespace:TwitchChatMvp.Controls"
        xmlns:models="clr-namespace:TwitchChatMvp.Models"
        xmlns:services="clr-namespace:TwitchChatMvp.Services"
        Title="{DynamicResource AppTitle}"
        Icon="/Assets/WitherChat.ico"
        Width="1100"
        Height="760"
        MinWidth="860"
        MinHeight="560"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Background="{DynamicResource AppBackground}">
        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-220,-240,0,0"
                 Opacity="0.16"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#664A7DFF" Offset="0" />
                    <GradientStop Color="#104A7DFF" Offset="0.62" />
                    <GradientStop Color="#004A7DFF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-210,-210"
                 Opacity="0.12"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6678F0D2" Offset="0" />
                    <GradientStop Color="#1078F0D2" Offset="0.6" />
                    <GradientStop Color="#0078F0D2" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <WrapPanel VerticalAlignment="Center">
                        <Grid Width="32" Height="32" Margin="0,0,10,0" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}">
                            <Ellipse Visibility="{Binding HasProfileImage, Converter={StaticResource BoolToVisibility}}">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding ProfileImageUrl}" Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <Border Background="#26FFFFFF"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Visibility="{Binding ShowAvatarPlaceholder, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding AvatarInitial}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>

                        <StackPanel Margin="0,0,14,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HeaderTitle}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}"
                                       MaxWidth="220"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding HeaderSubtitle}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedText}" />
                        </StackPanel>

                        <Border Style="{StaticResource StatusPillStyle}"
                                ToolTip="{Binding StatusText}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding ConnectionIndicatorBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding ConnectionStateText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusPillStyle}"
                                ToolTip="{Binding StatusText}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding ChatIndicatorBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding ChatConnectionStateText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusPillStyle}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding StreamIndicatorBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding StreamStatusText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryText}" />
                                <TextBlock Text="{Binding StreamViewerText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Command="{Binding OpenChatLogsCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="{DynamicResource ChatLogs}"
                                Margin="0,0,8,0">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                        </Button>
                        <Button Content="{DynamicResource ConnectTwitch}"
                                Command="{Binding ConnectCommand}"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibility}}" />
                        <Button Content="{DynamicResource SignInToSend}"
                                Command="{Binding SignInCommand}"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                Visibility="{Binding IsReadOnlyMode, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0" />

                        <Button Command="{Binding ToggleFiltersCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="{DynamicResource Filters}"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>

                            <StackPanel Orientation="Horizontal"
                                     Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}">
                            <Button Command="{Binding LogoutCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{Binding DisconnectButtonToolTip}"
                                    Margin="0,0,8,0">
                                <Path Data="M6,4 L13,4 L13,8 M13,16 L13,20 L6,20 Z M11,12 L21,12 M17,8 L21,12 L17,16"
                                      Stroke="{DynamicResource PrimaryText}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform"
                                      Width="18"
                                      Height="18" />
                            </Button>

                            <Button Command="{Binding ReconnectCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{DynamicResource ReconnectChat}"
                                    services:AnimationService.AnimationRole="ReconnectSpin"
                                    Margin="0,0,8,0">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                            </Button>

                            <Button Command="{Binding OpenSettingsCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    services:AnimationService.AnimationRole="SettingsGear"
                                    ToolTip="{DynamicResource Settings}">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource SubtleGlassCardStyle}"
                    Padding="10"
                    Visibility="{Binding FiltersVisible, Converter={StaticResource BoolToVisibility}}">
                <WrapPanel VerticalAlignment="Center">
                    <Grid Width="240" Height="40" Margin="0,0,10,0">
                        <TextBox x:Name="MessageSearchTextBox"
                                 Height="40"
                                 MinHeight="40"
                                 Padding="13,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource TinyTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{DynamicResource SearchTooltip}" />
                        <TextBlock Text="{DynamicResource SearchMessages}"
                                   Margin="13,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedText}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=MessageSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBox Width="170"
                              Style="{StaticResource TinyTextBoxStyle}"
                              Text="{Binding UserFilter, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{DynamicResource UserFilterTooltip}"
                             Margin="0,0,10,0" />
                    <Button Content="A-"
                            Command="{Binding DecreaseFontCommand}"
                            Style="{StaticResource SmallToolButtonStyle}"
                            ToolTip="{DynamicResource DecreaseFont}"
                            Margin="0,0,6,0" />
                    <Button Content="A+"
                            Command="{Binding IncreaseFontCommand}"
                            Style="{StaticResource SmallToolButtonStyle}"
                            ToolTip="{DynamicResource IncreaseFont}"
                            Margin="0,0,10,0" />
                    <CheckBox Content="{DynamicResource TimeShort}"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ShowTimestamps}"
                              Margin="0,0,10,0" />
                    <Button Content="{DynamicResource Clear}"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource SmallToolButtonStyle}" />
                </WrapPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource GlassCardStyle}" Padding="8">
                <Grid>
                    <ListBox x:Name="MessagesList"
                             ItemsSource="{Binding FilteredMessages}"
                             FontSize="{Binding FontSize}"
                             Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                             Loaded="MessagesList_Loaded"
                             behaviors:MiddleMouseAutoScrollBehavior.IsEnabled="True"
                             PreviewMouseWheel="MessagesList_PreviewMouseWheel"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ChatScrollBarStyle}" />
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatMessageModel}">
                                <Border Style="{StaticResource MessageCompactRowStyle}"
                                        MouseRightButtonDown="MessageItem_MouseRightButtonDown">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                     Opened="MessageContextMenu_Opened">
                                            <Border Style="{StaticResource ContextMenuHeaderStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Width="32"
                                                            Height="32"
                                                            CornerRadius="16"
                                                            Background="{DynamicResource ButtonBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrushSoft}"
                                                            BorderThickness="1">
                                                        <TextBlock Text="{Binding AvatarInitial}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding NickBrush}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding UserLabel}"
                                                                       Foreground="{Binding NickBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center" />
                                                            <ItemsControl ItemsSource="{Binding Badges}"
                                                                          Margin="7,0,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Visibility="{Binding DataContext.ShowBadges, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Image Width="16"
                                                                               Height="16"
                                                                               Source="{Binding ImageSource}"
                                                                               ToolTip="{Binding ToolTip}"
                                                                               Stretch="Uniform"
                                                                               Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                                               Margin="0,0,3,0" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LoginLabel}"
                                                                   Foreground="{DynamicResource MutedText}"
                                                                   FontSize="11"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <Separator Tag="ModerationSeparator" />
                                            <MenuItem Header="{DynamicResource BanUser}" Click="BanUser_Click" Tag="Danger">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE711;" Style="{StaticResource MenuIconTextStyle}" Foreground="{DynamicResource DangerBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource TimeoutTen}" Click="TimeoutTen_Click" Tag="Danger">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE823;" Style="{StaticResource MenuIconTextStyle}" Foreground="{DynamicResource DangerBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource TimeoutCustom}" Click="TimeoutCustom_Click" Tag="Danger">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE121;" Style="{StaticResource MenuIconTextStyle}" Foreground="{DynamicResource DangerBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="{DynamicResource CopyUsername}" Click="CopyUsername_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE77B;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource CopyMessage}" Click="CopyMessage_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8C8;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource OpenOnTwitch}" Click="OpenUser_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8A7;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <WrapPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TimeText}"
                                                   Visibility="{Binding DataContext.ShowTimestamps, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}"
                                                   Foreground="{DynamicResource MutedText}"
                                                   FontSize="11"
                                                   Margin="0,2,8,0"
                                                   VerticalAlignment="Center" />

                                        <ItemsControl ItemsSource="{Binding Badges}"
                                                      Margin="0,0,5,0"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding DataContext.ShowBadges, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Image Width="18"
                                                           Height="18"
                                                           Source="{Binding ImageSource}"
                                                           ToolTip="{Binding ToolTip}"
                                                           Stretch="Uniform"
                                                           Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                           Margin="0,0,3,0" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="{Binding UserLabel}"
                                                   Foreground="{Binding NickBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,1,6,0"
                                                   VerticalAlignment="Center" />

                                        <ItemsControl ItemsSource="{Binding Parts}" VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Center"
                                                          Margin="{Binding DisplayMargin}">
                                                        <controls:AnimatedEmoteImage Width="28"
                                                                                     Height="28"
                                                                                     Media="{Binding Media}"
                                                                                     Stretch="Uniform"
                                                                                     ToolTip="{Binding ToolTip}"
                                                                                     Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                                                     RenderOptions.BitmapScalingMode="HighQuality" />
                                                        <TextBlock Text="{Binding Text}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource PrimaryText}"
                                                                   Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibility}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </WrapPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid x:Name="JumpToLatestHost"
                          Width="50"
                          Height="54"
                          Margin="0,0,22,16"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Panel.ZIndex="10"
                          Opacity="0"
                          Visibility="Collapsed">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="8" />
                        </Grid.RenderTransform>
                        <Button x:Name="JumpToLatestButton"
                                Width="42"
                                Height="42"
                                MinHeight="42"
                                Padding="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushBright}"
                                Effect="{DynamicResource SoftShadow}"
                                Click="JumpToLatestButton_Click">
                            <Path Width="20"
                                  Height="20"
                                  Data="M4,7 L10,13 L16,7 M10,2 L10,13"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource PrimaryText}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Button>
                        <Border x:Name="UnreadMessagesBadge"
                                MinWidth="20"
                                Height="20"
                                Padding="5,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                CornerRadius="10"
                                Background="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource AppBackground}"
                                BorderThickness="2"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <TextBlock x:Name="UnreadMessagesText"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource SubtleGlassCardStyle}"
                            Padding="24"
                            MaxWidth="580"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding ShowChatEmptyState, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{Binding ChatEmptyTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding ChatEmptyText}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,9,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SubtleGlassCardStyle}"
                            Padding="28"
                            MaxWidth="560"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource AppName}"
                                       Style="{StaticResource WindowTitleTextStyle}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{DynamicResource SignInHelp}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10,0,22" />
                            <Button Content="{DynamicResource ConnectTwitch}"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                    MinWidth="210"
                                    HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="6"
                    Style="{StaticResource SubtleGlassCardStyle}"
                    Padding="8"
                    Visibility="{Binding ShowMessageComposer, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageInput"
                             Grid.Column="0"
                             MinHeight="38"
                             MaxHeight="92"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding OutgoingMessage, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="MessageInput_PreviewKeyDown"
                             ToolTip="{DynamicResource EnterSendTooltip}"
                             Style="{StaticResource InputMessageTextBoxStyle}" />

                    <Button Grid.Column="1"
                            Content="{DynamicResource Send}"
                            MinWidth="112"
                            Command="{Binding SendMessageCommand}"
                            ToolTip="{Binding SendButtonToolTip}"
                            ToolTipService.ShowOnDisabled="True"
                            Style="{StaticResource PrimaryCapsuleButtonStyle}"
                            Margin="8,0,0,0" />
                </Grid>
            </Border>

            <Border Grid.Row="6"
                    Style="{StaticResource SubtleGlassCardStyle}"
                    Padding="14"
                    Visibility="{Binding ShowReadOnlyComposerNotice, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ReadOnlyComposerText}"
                           Foreground="{DynamicResource MutedText}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Grid x:Name="OverlayHost"
              Visibility="Collapsed"
              Panel.ZIndex="100">
            <Border x:Name="OverlayScrim"
                    Background="#CC000000"
                    Opacity="0"
                    MouseDown="OverlayScrim_MouseDown" />
            <Border x:Name="OverlayPanelChrome"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="18"
                    MaxWidth="940"
                    Opacity="0">
                <ContentControl x:Name="OverlayContent" />
            </Border>
        </Grid>

        <Grid x:Name="DialogOverlayHost"
              Visibility="Collapsed"
              Panel.ZIndex="200">
            <Border x:Name="DialogScrim"
                    Background="#B3000000"
                    Opacity="0" />
            <Border x:Name="DialogCard"
                    Style="{StaticResource GlassCardStyle}"
                    Width="460"
                    MaxWidth="520"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0">
                <StackPanel>
                    <TextBlock x:Name="DialogTitleText"
                               Style="{StaticResource SectionTitleTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DialogMessageText"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,12,0,20"
                               TextWrapping="Wrap" />
                    <WrapPanel HorizontalAlignment="Right">
                        <Button x:Name="DialogCancelButton"
                                Content="{DynamicResource Cancel}"
                                Click="DialogCancel_Click"
                                Margin="0,0,8,0" />
                        <Button x:Name="DialogOkButton"
                                Content="OK"
                                Click="DialogOk_Click"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Text="{DynamicResource VersionLine}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,24,4"
                   Foreground="{DynamicResource MutedText}"
                   FontSize="11"
                   Panel.ZIndex="5" />
    </Grid>
</Window>

