<UserControl x:Class="TwitchChatMvp.Views.ConnectTwitchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackground}"
             Foreground="{DynamicResource PrimaryText}"
             FontFamily="{DynamicResource AppFontFamily}">
    <Grid Background="{DynamicResource AppBackground}" Margin="24" MaxWidth="620">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{DynamicResource ConnectTwitch}"
                       Style="{StaticResource WindowTitleTextStyle}" />
            <TextBlock Text="{DynamicResource ConnectTwitchIntro}"
                       Foreground="{DynamicResource SecondaryText}"
                       TextWrapping="Wrap"
                       Margin="1,7,0,0" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Click="SignIn_Click"
                    HorizontalContentAlignment="Stretch"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent">
                <Border Style="{StaticResource GlassCardStyle}" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="34"
                                Height="34"
                                CornerRadius="17"
                                Background="{DynamicResource AccentGradientBrush}">
                            <TextBlock Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{DynamicResource PrimaryButtonTextBrush}"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource SignInWithTwitch}"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="{DynamicResource PrimaryText}" />
                            <TextBlock Text="{DynamicResource FullAccessDescription}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>

            <Border Grid.Row="2"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="34"
                                Height="34"
                                CornerRadius="17"
                                Background="#262F5AE8"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1">
                            <TextBlock Text="&#xE890;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource WatchChannelWithoutSignIn}"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="{DynamicResource PrimaryText}" />
                            <TextBlock Text="{DynamicResource WatchOnlyDescription}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="ChannelLoginText"
                                     Height="42"
                                     MinHeight="42"
                                     Padding="14,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="{DynamicResource TwitchChannelName}"
                                     TextChanged="ChannelLoginText_TextChanged"
                                     PreviewKeyDown="ChannelLoginText_PreviewKeyDown"
                                     Style="{StaticResource TinyTextBoxStyle}" />
                            <TextBlock Text="{DynamicResource TwitchChannelName}"
                                       Margin="14,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="13"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=ChannelLoginText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ProgressBar x:Name="ChannelSearchProgress"
                                         Width="18"
                                         Height="3"
                                         Margin="0,0,14,0"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         IsIndeterminate="True"
                                         Visibility="Collapsed" />
                        </Grid>
                        <Button Grid.Column="2"
                                Width="128"
                                Height="42"
                                MinHeight="42"
                                Content="{DynamicResource Connect}"
                                Click="WatchOnly_Click"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}" />
                        <Popup x:Name="ChannelSuggestionsPopup"
                               PlacementTarget="{Binding ElementName=ChannelLoginText}"
                               Placement="Bottom"
                               VerticalOffset="6"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Width="{Binding ActualWidth, ElementName=ChannelLoginText}"
                                    MaxHeight="350"
                                    Padding="6"
                                    CornerRadius="14"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <ListBox x:Name="ChannelSuggestionsList"
                                             MaxHeight="324"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             PreviewMouseLeftButtonUp="ChannelSuggestionsList_PreviewMouseLeftButtonUp">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="52">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="34" Height="34" VerticalAlignment="Center">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PrimaryText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding BroadcasterLogin, StringFormat=@{0}}"
                                                                       Foreground="{DynamicResource MutedText}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding GameName, StringFormat= · {0}}"
                                                                       Foreground="{DynamicResource MutedText}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="7" Height="7" Margin="0,0,5,0"
                                                                 Fill="{DynamicResource DangerBrush}"
                                                                 Visibility="{Binding IsLive, Converter={StaticResource BoolToVisibility}}" />
                                                        <TextBlock Text="{DynamicResource StreamLive}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource DangerBrush}"
                                                                   Visibility="{Binding IsLive, Converter={StaticResource BoolToVisibility}}" />
                                                        <TextBlock Text="{DynamicResource ChannelSearchOffline}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource MutedText}"
                                                                   Visibility="{Binding IsLive, Converter={StaticResource InverseBoolToVisibility}}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock x:Name="ChannelSearchStatus"
                                               Margin="10,8"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="11"
                                               Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="4"
                   Foreground="{DynamicResource DangerBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />
    </Grid>
</UserControl>
