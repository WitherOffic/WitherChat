<UserControl x:Class="TwitchChatMvp.Views.ChatLogsPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TwitchChatMvp.Models"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}">
    <Grid Background="{DynamicResource AppBackground}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{DynamicResource ChatLogs}" Style="{StaticResource WindowTitleTextStyle}" />
            <TextBlock x:Name="RootFolderText"
                       Foreground="{DynamicResource MutedText}"
                       FontSize="12"
                       Margin="1,6,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SubtleGlassCardStyle}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{DynamicResource Channels}" Style="{StaticResource CaptionTextStyle}" Margin="2,0,0,8" />
                    <ListBox x:Name="ChannelsList"
                             Grid.Row="1"
                             SelectionChanged="ChannelsList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatLogChannelSummary}">
                                <Border Style="{StaticResource MessageCompactRowStyle}" Padding="10,7">
                                    <TextBlock Text="{Binding Login}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="3" Text="{DynamicResource Streams}" Style="{StaticResource CaptionTextStyle}" Margin="2,0,0,8" />
                    <ListBox x:Name="SessionsList"
                             Grid.Row="4"
                             SelectionChanged="SessionsList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatLogSessionSummary}">
                                <Border Style="{StaticResource MessageCompactRowStyle}" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayDate}"
                                                   Foreground="{DynamicResource MutedText}"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding MessageCountText}"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontSize="11"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="SessionTitleText"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="SessionMetaText"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" Margin="10,0,0,0">
                            <Button Content="{DynamicResource OpenFolder}"
                                    Click="OpenFolder_Click"
                                    Style="{StaticResource SmallToolButtonStyle}"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource ExportTxt}"
                                    Click="ExportTxt_Click"
                                    Style="{StaticResource SmallToolButtonStyle}"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource ExportJsonl}"
                                    Click="ExportJsonl_Click"
                                    Style="{StaticResource SmallToolButtonStyle}"
                                    Margin="0,0,8,8" />
                            <Button Content="{DynamicResource DeleteLog}"
                                    Click="DeleteLog_Click"
                                    Style="{StaticResource DangerCapsuleButtonStyle}"
                                    Margin="0,0,0,8" />
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource TinyTextBoxStyle}"
                                 ToolTip="{DynamicResource Search}"
                                 TextChanged="Filter_TextChanged" />
                        <TextBox x:Name="UserTextBox"
                                 Grid.Column="2"
                                 Style="{StaticResource TinyTextBoxStyle}"
                                 ToolTip="{DynamicResource User}"
                                 TextChanged="Filter_TextChanged" />
                        <ComboBox x:Name="RoleCombo"
                                  Grid.Column="4"
                                  MinHeight="32"
                                  SelectedIndex="0"
                                  SelectionChanged="RoleCombo_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource AllRoles}" Tag="" />
                            <ComboBoxItem Content="{DynamicResource BroadcasterRole}" Tag="broadcaster" />
                            <ComboBoxItem Content="{DynamicResource ModeratorRole}" Tag="moderator" />
                            <ComboBoxItem Content="{DynamicResource SubscriberRole}" Tag="subscriber" />
                            <ComboBoxItem Content="{DynamicResource VipRole}" Tag="vip" />
                        </ComboBox>
                    </Grid>

                    <ListBox x:Name="MessagesList"
                             Grid.Row="4"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatLogMessageEntry}">
                                <Border Style="{StaticResource MessageCompactRowStyle}">
                                    <WrapPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TimeText}"
                                                   Foreground="{DynamicResource MutedText}"
                                                   FontSize="11"
                                                   Margin="0,2,8,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding BadgeText}"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontSize="11"
                                                   Margin="0,2,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding UserLabel}"
                                                   Foreground="{Binding NickBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,1,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </WrapPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Foreground="{DynamicResource SecondaryText}"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</UserControl>
