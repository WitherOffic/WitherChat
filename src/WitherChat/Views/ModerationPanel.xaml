<UserControl x:Class="WitherChat.Views.ModerationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackground}"
             Foreground="{DynamicResource PrimaryText}"
             FontFamily="{DynamicResource AppFontFamily}"
             FontWeight="{DynamicResource AppFontWeight}"
             MinWidth="720"
             MinHeight="520">
    <UserControl.Resources>
        <Style x:Key="ModerationCompactButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ModerationCompactPrimaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PrimaryCapsuleButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ChatScrollBarStyle}" />
        <Style x:Key="ModerationListStyle"
               TargetType="{x:Type ListBox}"
               BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Padding" Value="0,0,6,6" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>
        <Style x:Key="ModerationTabButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Chrome"
                                Height="32"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentGradientBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModerationContentTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <ContentPresenter ContentSource="SelectedContent"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ContextMenu x:Key="ModerationUserContextMenu"
                     x:Shared="False"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="{DynamicResource RecentMessages}" Click="RecentMessages_Click">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8BD;" Style="{StaticResource MenuIconTextStyle}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{DynamicResource OpenOnTwitch}" Click="OpenUserOnTwitch_Click">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8A7;" Style="{StaticResource MenuIconTextStyle}" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="24,22,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Moderation}" Style="{StaticResource WindowTitleTextStyle}" />
                <TextBlock Text="{Binding ActiveChannel.ChannelLogin, StringFormat=@{0}}"
                           Foreground="{DynamicResource MutedText}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="×" Click="Close_Click" Style="{StaticResource IconButtonStyle}" />
        </Grid>

        <Grid Grid.Row="1"
              Visibility="{Binding ActiveChannel.HasConfirmedModerationAccess, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <RadioButton Content="{DynamicResource AutoMod}"
                             GroupName="ModerationTabs"
                             Tag="0"
                             IsChecked="True"
                             Checked="ModerationTab_Checked"
                             Style="{StaticResource ModerationTabButtonStyle}" />
                <RadioButton Content="{DynamicResource BannedUsers}"
                             GroupName="ModerationTabs"
                             Tag="1"
                             Checked="ModerationTab_Checked"
                             Style="{StaticResource ModerationTabButtonStyle}" />
                <RadioButton Content="{DynamicResource UnbanRequests}"
                             GroupName="ModerationTabs"
                             Tag="2"
                             Checked="ModerationTab_Checked"
                             Style="{StaticResource ModerationTabButtonStyle}" />
            </StackPanel>

            <TabControl x:Name="ModerationTabs"
                        Grid.Row="2"
                        SelectedIndex="0"
                        Style="{StaticResource ModerationContentTabControlStyle}">
            <TabItem>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="AutoModStatusText"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="2,0,2,10"
                               TextWrapping="Wrap" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ActiveChannel.PendingAutoModMessages}"
                             Style="{StaticResource ModerationListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SubtleGlassCardStyle}"
                                        Padding="14"
                                        Margin="0,0,0,9"
                                        ContextMenu="{StaticResource ModerationUserContextMenu}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding LoginLabel}" Foreground="{DynamicResource MutedText}" Margin="7,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="{DynamicResource MutedText}" FontSize="11" />
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding MessageText}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                        <Grid Grid.Row="2" Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding CategoryLabel}" Foreground="{DynamicResource MutedText}" FontSize="11" />
                                                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" FontSize="11" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="{DynamicResource Allow}" Click="Allow_Click" Margin="0,0,8,0"
                                                        Style="{StaticResource ModerationCompactButtonStyle}" />
                                                <Button Content="{DynamicResource Deny}" Click="Deny_Click"
                                                        Style="{StaticResource ModerationCompactPrimaryButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveChannel.BannedUsersStatus}" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ActiveChannel.BannedUsersLoadError}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="{DynamicResource RefreshList}" Click="RefreshBanned_Click"
                                IsEnabled="{Binding ActiveChannel.CanRefreshBannedUsers}"
                                Style="{StaticResource ModerationCompactButtonStyle}" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,10,0,10" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="UserLoginText"
                                     Height="38"
                                     MinHeight="38"
                                     Padding="13,0"
                                     VerticalContentAlignment="Center"
                                     Style="{StaticResource TinyTextBoxStyle}"
                                     ToolTip="{DynamicResource UserLogin}"
                                     TextChanged="UserLoginText_TextChanged" />
                            <TextBlock x:Name="UserLoginPlaceholder"
                                       Text="{DynamicResource UserLogin}"
                                       Foreground="{DynamicResource MutedText}"
                                       Margin="14,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                        </Grid>
                        <Button Grid.Column="1" Content="{DynamicResource Unban}" Click="UnbanByLogin_Click" Margin="8,0,0,0"
                                Style="{StaticResource ModerationCompactPrimaryButtonStyle}" />
                    </Grid>
                    <ListBox Grid.Row="2" ItemsSource="{Binding ActiveChannel.BannedUsers}"
                             Style="{StaticResource ModerationListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SubtleGlassCardStyle}"
                                        Padding="12,10"
                                        Margin="0,0,0,7"
                                        ContextMenu="{StaticResource ModerationUserContextMenu}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding UserLogin, StringFormat=@{0}}" Foreground="{DynamicResource MutedText}" FontSize="12" />
                                            <TextBlock Text="{Binding Reason}" Foreground="{DynamicResource SecondaryText}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{Binding ActionLabel}" Click="RemovePunishment_Click" Margin="12,0,0,0"
                                                Style="{StaticResource ModerationCompactButtonStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="3"
                            Content="{DynamicResource LoadMore}"
                            Click="LoadMoreBanned_Click"
                            IsEnabled="{Binding ActiveChannel.CanRefreshBannedUsers}"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"
                            Style="{StaticResource ModerationCompactButtonStyle}" />
                </Grid>
            </TabItem>

            <TabItem>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ActiveChannel.UnbanRequestsStatus}" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" />
                        <Button Grid.Column="1" Content="{DynamicResource RefreshList}" Click="RefreshUnbanRequests_Click"
                                Style="{StaticResource ModerationCompactButtonStyle}" />
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
                        <RadioButton Content="{DynamicResource UnbanPending}"
                                     GroupName="UnbanRequestStatus"
                                     IsChecked="True"
                                     Click="PendingUnbanRequests_Click"
                                     Style="{StaticResource ModerationTabButtonStyle}" />
                        <RadioButton Content="{DynamicResource UnbanApproved}"
                                     GroupName="UnbanRequestStatus"
                                     Click="ApprovedUnbanRequests_Click"
                                     Style="{StaticResource ModerationTabButtonStyle}" />
                        <RadioButton Content="{DynamicResource UnbanDenied}"
                                     GroupName="UnbanRequestStatus"
                                     Click="DeniedUnbanRequests_Click"
                                     Style="{StaticResource ModerationTabButtonStyle}" />
                    </StackPanel>
                    <ListBox x:Name="UnbanRequestsList" Grid.Row="2" ItemsSource="{Binding ActiveChannel.UnbanRequests}"
                             Style="{StaticResource ModerationListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SubtleGlassCardStyle}"
                                        Padding="14"
                                        Margin="0,0,0,9"
                                        ContextMenu="{StaticResource ModerationUserContextMenu}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="36" Height="36" VerticalAlignment="Top">
                                            <Ellipse Fill="{DynamicResource PanelAltBackground}" />
                                            <Image Source="{Binding ProfileImageUrl}" Stretch="UniformToFill" />
                                            <TextBlock Text="{Binding AvatarInitial}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding UserLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding LoginLabel}" Foreground="{DynamicResource MutedText}" Margin="7,0,0,0" />
                                                <TextBlock Text="{Binding CreatedAtText}" Foreground="{DynamicResource MutedText}" FontSize="11" Margin="10,1,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding RequestText}" TextWrapping="Wrap" Margin="0,7,0,0" />
                                            <TextBlock Text="{Binding ResolutionText}" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Top">
                                            <Button Content="{DynamicResource Approve}" Click="ApproveUnbanRequest_Click" Margin="0,0,8,0"
                                                    IsEnabled="{Binding CanResolve}" Style="{StaticResource ModerationCompactPrimaryButtonStyle}" />
                                            <Button Content="{DynamicResource Deny}" Click="DenyUnbanRequest_Click"
                                                    IsEnabled="{Binding CanResolve}" Style="{StaticResource ModerationCompactButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="3" Content="{DynamicResource LoadMore}" Click="LoadMoreUnbanRequests_Click"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Style="{StaticResource ModerationCompactButtonStyle}" />
                </Grid>
            </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource SubtleGlassCardStyle}"
                Padding="24"
                MaxWidth="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ActiveChannel.HasConfirmedModerationAccess, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="{DynamicResource NoModeratorPermissions}"
                           Style="{StaticResource SectionTitleTextStyle}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border x:Name="RecentMessagesPanel"
                Grid.RowSpan="2"
                Width="620"
                MaxHeight="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="18"
                Panel.ZIndex="20"
                Style="{StaticResource GlassCardStyle}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource RecentMessages}"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock x:Name="RecentMessagesUserText"
                                   Foreground="{DynamicResource MutedText}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="×"
                            Click="CloseRecentMessages_Click"
                            Style="{StaticResource IconButtonStyle}" />
                </Grid>
                <Grid Grid.Row="2">
                    <TextBlock x:Name="NoRecentMessagesText"
                               Text="{DynamicResource NoRecentMessages}"
                               Foreground="{DynamicResource SecondaryText}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <ListBox x:Name="RecentMessagesList"
                             Style="{StaticResource ModerationListStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MessageCompactRowStyle}" Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}"
                                                   Foreground="{DynamicResource MutedText}"
                                                   FontSize="11" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Text}"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
