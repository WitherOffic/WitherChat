<Window x:Class="WitherChat.Views.CustomTimeoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource CustomTimeoutTitle}"
        Icon="/Assets/WitherChat.ico"
        Width="520"
        Height="570"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}"
        FontWeight="{DynamicResource AppFontWeight}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource CustomTimeoutTitle}" Style="{StaticResource SectionTitleTextStyle}" />

        <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="86" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Width="40" Height="40">
                        <Ellipse Fill="{DynamicResource PanelAltBackground}" />
                        <Image x:Name="AvatarImage" ClipToBounds="True" Stretch="UniformToFill" />
                        <TextBlock x:Name="AvatarInitialText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="SemiBold" FontSize="16" />
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="DisplayNameText" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="LoginAndChannelText" Foreground="{DynamicResource MutedText}" FontSize="12" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2" Text="{DynamicResource Duration}" Style="{StaticResource CaptionTextStyle}" />
                <ComboBox x:Name="QuickDurationCombo" Grid.Row="4" SelectionChanged="QuickDurationCombo_SelectionChanged" />

                <Grid x:Name="CustomDurationPanel" Grid.Row="6" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CustomDurationText" Style="{StaticResource NumericTextBoxStyle}" Text="1" MaxLength="7" />
                    <ComboBox x:Name="DurationUnitCombo" Grid.Column="2" />
                </Grid>

                <TextBlock Grid.Row="8" x:Name="ReasonLabel" Text="{DynamicResource Reason}" Style="{StaticResource CaptionTextStyle}" />
                <Grid Grid.Row="10">
                    <TextBox x:Name="ReasonText" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                             MaxLength="500" Padding="13,11,13,22" TextChanged="ReasonText_TextChanged" />
                    <TextBlock x:Name="ReasonPlaceholder" Text="{DynamicResource ReasonOptional}"
                               Foreground="{DynamicResource MutedText}" IsHitTestVisible="False"
                               Margin="14,11,14,0" VerticalAlignment="Top" />
                    <TextBlock x:Name="ReasonCountText" Text="0 / 500" Foreground="{DynamicResource MutedText}"
                               FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,7" />
                </Grid>

                <TextBlock x:Name="ErrorText" Grid.Row="11" Foreground="{DynamicResource DangerBrush}"
                           FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed" />
            </Grid>
        </Border>

        <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Cancel}" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="{DynamicResource ApplyTimeout}" Click="Apply_Click"
                    Style="{StaticResource PrimaryCapsuleButtonStyle}" />
        </WrapPanel>
    </Grid>
</Window>
