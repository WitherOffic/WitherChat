<Window x:Class="WitherChat.Views.SilentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppName}"
        Icon="/Assets/WitherChat.ico"
        Width="460"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}"
        FontWeight="{DynamicResource AppFontWeight}">
    <Grid Background="{DynamicResource AppBackground}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource GlassCardStyle}" Padding="22">
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Style="{StaticResource SectionTitleTextStyle}"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="MessageText"
                           Foreground="{DynamicResource SecondaryText}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="{DynamicResource Cancel}"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"
                    Visibility="Collapsed" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Click="Ok_Click"
                    Style="{StaticResource PrimaryCapsuleButtonStyle}" />
        </WrapPanel>
    </Grid>
</Window>
