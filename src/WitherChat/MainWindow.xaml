<Window x:Class="WitherChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:WitherChat.Behaviors"
        xmlns:controls="clr-namespace:WitherChat.Controls"
        xmlns:models="clr-namespace:WitherChat.Models"
        xmlns:services="clr-namespace:WitherChat.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource AppTitle}"
        Icon="/WitherChat;component/Assets/WitherChat.ico"
        Width="1100"
        Height="760"
        MinWidth="860"
        MinHeight="560"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}"
        FontWeight="{DynamicResource AppFontWeight}"
        Topmost="{Binding AlwaysOnTop}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="7"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TrafficLightButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="MinWidth" Value="14" />
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#99000000" />
            <Setter Property="FontFamily" Value="Segoe UI Variable" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Ellipse x:Name="Circle"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="#24000000"
                                     StrokeThickness="0.7"
                                     SnapsToDevicePixels="True" />
                            <ContentPresenter x:Name="Glyph"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,0"
                                              Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                                <Setter TargetName="Circle" Property="Stroke" Value="#48000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelVisibilityToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="20" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource AppBackground}">
        <Border x:Name="CustomTitleBar"
                Panel.ZIndex="100"
                Height="42"
                VerticalAlignment="Top"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="{Binding WindowControlsAlignment}"
                            FlowDirection="{Binding WindowControlsFlowDirection}"
                            VerticalAlignment="Center"
                            Margin="15,0">
                    <Button Content="×"
                            Background="#FFFF5F57"
                            ToolTip="{DynamicResource Close}"
                            Style="{StaticResource TrafficLightButtonStyle}"
                            Click="CloseTitleBarButton_Click" />
                    <Button Content="-"
                            Background="#FFFFBD2E"
                            ToolTip="{DynamicResource Minimize}"
                            Style="{StaticResource TrafficLightButtonStyle}"
                            Margin="8,0,0,0"
                            Click="MinimizeTitleBarButton_Click" />
                    <Button Content="+"
                            Background="#FF28C840"
                            ToolTip="{DynamicResource Maximize}"
                            Style="{StaticResource TrafficLightButtonStyle}"
                            Margin="8,0,0,0"
                            Click="MaximizeTitleBarButton_Click" />
                </StackPanel>

                <TextBlock Text="{DynamicResource AppTitle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           IsHitTestVisible="False" />
            </Grid>
        </Border>

        <Border Panel.ZIndex="99"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                IsHitTestVisible="False" />

        <Ellipse Width="420"
                 Height="420"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-220,-240,0,0"
                 Opacity="0.16"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#664A7DFF" Offset="0" />
                    <GradientStop Color="#104A7DFF" Offset="0.62" />
                    <GradientStop Color="#004A7DFF" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="360"
                 Height="360"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-210,-210"
                 Opacity="0.12"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6678F0D2" Offset="0" />
                    <GradientStop Color="#1078F0D2" Offset="0.6" />
                    <GradientStop Color="#0078F0D2" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="16,54,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderPanel"
                    Grid.Row="0"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="14,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ChannelSwitcherButton"
                                Grid.Column="0"
                                Command="{Binding ToggleChannelSwitcherCommand}"
                                Style="{StaticResource ChannelAccountButtonStyle}"
                                ToolTip="{DynamicResource Channels}">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="32" Height="32" Margin="0,0,10,0">
                                    <Ellipse Visibility="{Binding HasProfileImage, Converter={StaticResource BoolToVisibility}}">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ProfileImageUrl}" Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Border Background="{DynamicResource ButtonBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Visibility="{Binding ShowAvatarPlaceholder, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding AvatarInitial}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding HeaderTitle}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"
                                               MaxWidth="190"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding HeaderSubtitle}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryText}"
                                               MaxWidth="190"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ActiveChannelLabel}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MutedText}" />
                                </StackPanel>
                            </StackPanel>
                    </Button>

                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="12,0">
                        <Border Style="{StaticResource StatusPillStyle}"
                                ToolTip="{Binding StatusText}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding ConnectionIndicatorBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding ConnectionStateText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusPillStyle}"
                                ToolTip="{Binding StatusText}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding ChatIndicatorBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding ChatConnectionStateText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusPillStyle}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding StreamIndicatorBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding StreamStatusText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryText}" />
                                <TextBlock Text="{Binding StreamViewerText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatusPillStyle}"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsSharedChatActive, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M3,5 H11 V11 H7 L4,14 V11 H3 Z M13,7 H21 V13 H18 L15,16 V13 H13 Z"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="16"
                                      Height="14"
                                      Stretch="Uniform"
                                      Margin="0,0,7,0" />
                                <TextBlock Text="{Binding SharedChatStatusText}"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryText}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Command="{Binding OpenChatLogsCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="{DynamicResource ChatLogs}"
                                Margin="0,0,8,0">
                            <Path Data="M4,5 H20 V16 H10 L6,19 V16 H4 Z M8,9 H16 M8,12 H14"
                                  Stroke="{DynamicResource SecondaryText}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Width="17"
                                  Height="17" />
                        </Button>
                        <Button Command="{Binding OpenModerationCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="{DynamicResource Moderation}"
                                Visibility="{Binding CanModerate, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0">
                            <Path Data="M12,3 L20,6 V11 C20,16 16.5,19.5 12,21 C7.5,19.5 4,16 4,11 V6 Z M8.5,12 L11,14.5 L15.5,9.5"
                                  Stroke="{DynamicResource SecondaryText}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Width="17"
                                  Height="17" />
                        </Button>
                        <Button Content="{DynamicResource ConnectTwitch}"
                                Command="{Binding ConnectCommand}"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                Visibility="{Binding ShowConnectButton, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0" />
                        <Button Content="{Binding SignInButtonText}"
                                Command="{Binding SignInCommand}"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                Visibility="{Binding ShowSignInButton, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0" />
                        <Button Content="{DynamicResource CancelSignIn}"
                                Command="{Binding CancelSignInCommand}"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                Visibility="{Binding ShowCancelSignInButton, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0" />

                        <Button Command="{Binding ToggleFiltersCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="{DynamicResource Filters}"
                                Visibility="{Binding HasActiveChannel, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0">
                            <Path Data="M10.5,4 A6.5,6.5 0 1 0 10.5,17 A6.5,6.5 0 1 0 10.5,4 M15.2,15.2 L20,20"
                                  Stroke="{DynamicResource SecondaryText}"
                                  StrokeThickness="1.65"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Width="17"
                                  Height="17" />
                        </Button>

                        <Button Command="{Binding LogoutCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{Binding DisconnectButtonToolTip}"
                                    Margin="0,0,8,0"
                                    Visibility="{Binding ShowLogoutButton, Converter={StaticResource BoolToVisibility}}">
                                <Path Data="M5,4 H12 V8 M12,16 V20 H5 Z M10,12 H21 M17,8 L21,12 L17,16"
                                      Stroke="{DynamicResource SecondaryText}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform"
                                      Width="17"
                                      Height="17" />
                            </Button>

                            <Button Command="{Binding ReconnectCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{DynamicResource ReconnectChat}"
                                    services:AnimationService.AnimationRole="ReconnectSpin"
                                    Margin="0,0,8,0"
                                    Visibility="{Binding ShowReconnectButton, Converter={StaticResource BoolToVisibility}}">
                                <Path Data="M19,8 A8,8 0 1 0 20,14 M19,4 V9 H14"
                                      Stroke="{DynamicResource SecondaryText}"
                                      StrokeThickness="1.65"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform"
                                      Width="17"
                                      Height="17" />
                            </Button>

                            <Button Command="{Binding OpenSettingsCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="{DynamicResource Settings}">
                                <Path Data="M4,7 H8 M12,7 H20 M10,5 V9 M4,12 H14 M18,12 H20 M16,10 V14 M4,17 H6 M10,17 H20 M8,15 V19"
                                      Stroke="{DynamicResource SecondaryText}"
                                      StrokeThickness="1.65"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform"
                                      Width="17"
                                      Height="17" />
                            </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ToggleButton x:Name="HeaderPanelToggle"
                          Grid.Row="1"
                          IsChecked="True"
                          Margin="0,2"
                          Checked="HeaderPanelToggle_Checked"
                          Unchecked="HeaderPanelToggle_Unchecked"
                          Style="{StaticResource PanelVisibilityToggleStyle}">
                <Grid Width="16" Height="10">
                    <Path Data="M2,8 L8,2 L14,8"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="HeaderPanelChevronRotation" />
                        </Path.RenderTransform>
                    </Path>
                </Grid>
            </ToggleButton>

            <Border Grid.Row="2"
                    Padding="10">
                <Border.Style>
                    <Style TargetType="{x:Type Border}" BasedOn="{StaticResource SubtleGlassCardStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding FiltersVisible}" Value="True" />
                                    <Condition Binding="{Binding IsChecked, ElementName=HeaderPanelToggle}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <WrapPanel VerticalAlignment="Center">
                    <Grid Width="240" Height="40" Margin="0,0,10,0">
                        <TextBox x:Name="MessageSearchTextBox"
                                 Height="40"
                                 MinHeight="40"
                                 Padding="13,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource TinyTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{DynamicResource SearchTooltip}" />
                        <TextBlock Text="{DynamicResource SearchMessages}"
                                   Margin="13,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedText}"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=MessageSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBox Width="170"
                              Style="{StaticResource TinyTextBoxStyle}"
                              Text="{Binding UserFilter, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{DynamicResource UserFilterTooltip}"
                             Margin="0,0,10,0" />
                    <Button Content="A-"
                            Command="{Binding DecreaseFontCommand}"
                            Style="{StaticResource SmallToolButtonStyle}"
                            ToolTip="{DynamicResource DecreaseFont}"
                            Margin="0,0,6,0" />
                    <Button Content="A+"
                            Command="{Binding IncreaseFontCommand}"
                            Style="{StaticResource SmallToolButtonStyle}"
                            ToolTip="{DynamicResource IncreaseFont}"
                            Margin="0,0,10,0" />
                    <CheckBox Content="{DynamicResource TimeShort}"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ShowTimestamps}"
                              Margin="0,0,10,0" />
                    <Button Content="{DynamicResource Clear}"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource SmallToolButtonStyle}" />
                </WrapPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource GlassCardStyle}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="2,1,2,8"
                            Padding="12,9"
                            CornerRadius="10"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            Visibility="{Binding ActiveChannel.HasPinnedMessage, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Width="16"
                                  Height="16"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Margin="2,2,0,0"
                                  Data="M11,1 L15,5 L13,7 L16,10 L15,11 L11,8 L7,12 L8,16 L7,17 L5,13 L1,9 L2,8 L6,9 L10,5 L7,2 L8,1 Z"
                                  Fill="{DynamicResource AccentBrush}"
                                  Stretch="Uniform" />
                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource PinnedMessage}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ActiveChannel.PinnedMessage.SenderLabel}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontWeight="SemiBold"
                                               Margin="8,0,0,0" />
                                    <TextBlock Text="{DynamicResource PinnedBy}"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="11"
                                               Margin="12,2,4,0" />
                                    <TextBlock Text="{Binding ActiveChannel.PinnedMessage.PinnedByLabel}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding ActiveChannel.PinnedMessage.Text}"
                                           Foreground="{DynamicResource PrimaryText}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="42"
                                           Margin="0,3,0,0"
                                           ToolTip="{Binding ActiveChannel.PinnedMessage.Text}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListBox x:Name="MessagesList"
                             Grid.Row="1"
                             ItemsSource="{Binding FilteredMessages}"
                             FontSize="{Binding FontSize}"
                             Visibility="{Binding HasActiveChannel, Converter={StaticResource BoolToVisibility}}"
                             Loaded="MessagesList_Loaded"
                             behaviors:MiddleMouseAutoScrollBehavior.IsEnabled="True"
                             PreviewMouseWheel="MessagesList_PreviewMouseWheel"
                             PreviewKeyDown="MessagesList_PreviewKeyDown"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.PanningMode="VerticalOnly"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             VirtualizingPanel.CacheLength="2,2"
                             VirtualizingPanel.CacheLengthUnit="Page">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ChatScrollBarStyle}" />
                            <DataTemplate x:Key="ChannelPointsRedemptionTemplate">
                                <Border Margin="2,3"
                                        Padding="12,10"
                                        CornerRadius="12"
                                        Background="{DynamicResource ButtonBackgroundBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="32" Height="32" VerticalAlignment="Top">
                                            <Ellipse Visibility="{Binding HasProfileImage, Converter={StaticResource BoolToVisibility}}">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding ProfileImageUrl}" Stretch="UniformToFill" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Border CornerRadius="16"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Visibility="{Binding HasProfileImage, Converter={StaticResource InverseBoolToVisibility}}">
                                                <TextBlock Text="&#xE735;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{DynamicResource PrimaryButtonTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding RedemptionSummary}"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Margin="0,5,0,0"
                                                        Visibility="{Binding HasRewardUserInput, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding RewardUserInputLabel}"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding RewardUserInput}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding Parts}" Margin="0,5,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="{Binding DisplayMargin}" ClipToBounds="False">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.TwitchEmote}">
                                                                            <Setter Property="Width" Value="{Binding DisplayWidth}" />
                                                                            <Setter Property="MinHeight" Value="{Binding DisplayHeight}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.ThirdPartyEmote}">
                                                                            <Setter Property="Width" Value="{Binding DisplayWidth}" />
                                                                            <Setter Property="MinHeight" Value="{Binding DisplayHeight}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <controls:AnimatedEmoteImage Width="{Binding DisplayWidth}"
                                                                                         Height="{Binding DisplayHeight}"
                                                                                         Media="{Binding Media}"
                                                                                         Stretch="Uniform"
                                                                                         Opacity="1"
                                                                                         Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}" />
                                                            <ItemsControl ItemsSource="{Binding OverlayParts}"
                                                                          Width="{Binding DisplayWidth}"
                                                                          Height="{Binding DisplayHeight}"
                                                                          ClipToBounds="False"
                                                                          Panel.ZIndex="1"
                                                                          Visibility="{Binding HasOverlays, Converter={StaticResource BoolToVisibility}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate><Grid /></ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <controls:AnimatedEmoteImage Width="{Binding DisplayWidth}"
                                                                                                     Height="{Binding DisplayHeight}"
                                                                                                     HorizontalAlignment="Center"
                                                                                                     VerticalAlignment="Center"
                                                                                                     Media="{Binding Media}"
                                                                                                     Stretch="Uniform"
                                                                                                     Opacity="1"
                                                                                                     Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{DynamicResource SecondaryText}"
                                                                       Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibility}}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="TextWrapping" Value="Wrap" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.TwitchEmote}">
                                                                                <Setter Property="TextWrapping" Value="NoWrap" />
                                                                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                                                <Setter Property="ToolTip" Value="{Binding Text}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.ThirdPartyEmote}">
                                                                                <Setter Property="TextWrapping" Value="NoWrap" />
                                                                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                                                <Setter Property="ToolTip" Value="{Binding Text}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding ChannelLogin, StringFormat=@{0}}"
                                                       Foreground="{DynamicResource MutedText}"
                                                       FontSize="10"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.Resources>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}"
                                   BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <EventSetter Event="Loaded" Handler="MessageListItem_Loaded" />
                                <EventSetter Event="Unloaded" Handler="MessageListItem_Unloaded" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ChatMessageModel}">
                                <Grid>
                                    <ContentControl Content="{Binding}"
                                                    ContentTemplate="{StaticResource ChannelPointsRedemptionTemplate}"
                                                    Visibility="{Binding IsChannelPointsRedemption, Converter={StaticResource BoolToVisibility}}" />
                                <Border Style="{StaticResource MessageCompactRowStyle}"
                                        Visibility="{Binding IsChannelPointsRedemption, Converter={StaticResource InverseBoolToVisibility}}"
                                        MouseRightButtonDown="MessageItem_MouseRightButtonDown">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                     Opened="MessageContextMenu_Opened">
                                            <Border Style="{StaticResource ContextMenuHeaderStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Column="0" Width="32" Height="32">
                                                        <Ellipse Visibility="{Binding HasProfileImage, Converter={StaticResource BoolToVisibility}}">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding ProfileImageUrl}" Stretch="UniformToFill" />
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <Border CornerRadius="16"
                                                                Background="{DynamicResource ButtonBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                                                BorderThickness="1"
                                                                Visibility="{Binding HasProfileImage, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <TextBlock Text="{Binding AvatarInitial}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding NickBrush}" />
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding UserLabel}"
                                                                       Foreground="{Binding NickBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center" />
                                                            <ItemsControl ItemsSource="{Binding Badges}"
                                                                          Margin="7,0,0,0"
                                                                          VerticalAlignment="Center"
                                                                          Visibility="{Binding DataContext.ShowBadges, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Image Width="16"
                                                                               Height="16"
                                                                               Source="{Binding ImageSource}"
                                                                               ToolTip="{Binding ToolTip}"
                                                                               Stretch="Uniform"
                                                                               Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                                               Margin="0,0,3,0" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LoginLabel}"
                                                                   Foreground="{DynamicResource MutedText}"
                                                                   FontSize="11"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <Separator Tag="ModerationSeparator" />
                                            <MenuItem Header="{DynamicResource DeleteMessage}" Click="DeleteMessage_Click" Tag="DeleteMessage">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE74D;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource BanUser}" Click="BanUser_Click" Tag="BanAction">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE711;" Style="{StaticResource MenuIconTextStyle}" Foreground="{DynamicResource DangerBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource TimeoutTen}" Click="TimeoutTen_Click" Tag="TimeoutAction">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE823;" Style="{StaticResource MenuIconTextStyle}" Foreground="{DynamicResource DangerBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource TimeoutCustom}" Click="TimeoutCustom_Click" Tag="TimeoutAction">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE121;" Style="{StaticResource MenuIconTextStyle}" Foreground="{DynamicResource DangerBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource RemovePunishment}"
                                                      Click="RemovePunishment_Click"
                                                      Tag="RemovePunishment"
                                                      Visibility="Collapsed">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE777;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="{DynamicResource CopyUsername}" Click="CopyUsername_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE77B;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource CopyMessage}" Click="CopyMessage_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8C8;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource OpenOnTwitch}" Click="OpenUser_Click">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE8A7;" Style="{StaticResource MenuIconTextStyle}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <StackPanel>
                                    <Border Background="{DynamicResource PanelAltBackground}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="2,0,0,0"
                                            CornerRadius="7"
                                            Padding="8,5"
                                            Margin="0,0,0,5"
                                            Opacity="{Binding ModeratedContentOpacity}"
                                            Visibility="{Binding HasReply, Converter={StaticResource BoolToVisibility}}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="&#xE8BD;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,1,6,0"
                                                       DockPanel.Dock="Left" />
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                <TextBlock Text="{DynamicResource ReplyingTo}"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding ReplyParentUserLabel}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11"
                                                           Margin="4,0,0,0" />
                                                <TextBlock Text=":"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="11"
                                                           Margin="1,0,5,0"
                                                           Visibility="{Binding HasReplyParentMessageBody, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ReplyParentMessageBody}"
                                                       Foreground="{DynamicResource MutedText}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ReplyParentMessageBody}" />
                                        </DockPanel>
                                    </Border>

                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}"
                                                   Grid.Column="0"
                                                   Visibility="{Binding DataContext.ShowTimestamps, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}"
                                                   Foreground="{DynamicResource MutedText}"
                                                   FontSize="11"
                                                   Margin="0,2,8,0"
                                                   VerticalAlignment="Center" />

                                        <ItemsControl ItemsSource="{Binding Badges}"
                                                      Grid.Column="1"
                                                      Margin="0,0,5,0"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding DataContext.ShowBadges, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibility}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                     <Image Width="18"
                                                            Height="18"
                                                            Source="{Binding ImageSource}"
                                                            ToolTip="{Binding ToolTip}"
                                                            Stretch="Uniform"
                                                            Margin="0,0,3,0" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Opacity="{Binding ModeratedContentOpacity}">
                                            <Path Width="12"
                                                  Height="12"
                                                  Margin="0,0,5,0"
                                                  VerticalAlignment="Center"
                                                  Data="M11,1 L15,5 L13,7 L16,10 L15,11 L11,8 L7,12 L8,16 L7,17 L5,13 L1,9 L2,8 L6,9 L10,5 L7,2 L8,1 Z"
                                                  Fill="{DynamicResource AccentBrush}"
                                                  Stretch="Uniform"
                                                  ToolTip="{DynamicResource PinnedMessage}"
                                                  Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}" />
                                            <Border Background="{DynamicResource PanelAltBackground}"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="5,1"
                                                    Margin="0,0,6,0"
                                                    Visibility="{Binding HasSourceChannelLabel, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding SourceChannelLabel}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontSize="10" />
                                            </Border>
                                            <TextBlock Text="{Binding UserLabel}"
                                                       Foreground="{Binding NickBrush}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,1,6,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    Opacity="{Binding ModeratedContentOpacity}">
                                            <Button Tag="LongMessageExpansion"
                                                    Click="MessageExpansionButton_Click"
                                                    Style="{StaticResource SmallToolButtonStyle}"
                                                    Height="22"
                                                    MinHeight="22"
                                                    Padding="7,0"
                                                    Margin="0,0,0,3"
                                                    HorizontalAlignment="Left"
                                                    Focusable="False"
                                                    Visibility="{Binding IsLongMessage, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock FontSize="10" Foreground="{DynamicResource SecondaryText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource ExpandMessage}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMessageExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="{DynamicResource CollapseMessage}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                            <Border ClipToBounds="True">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="MaxHeight" Value="100000" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLongMessage}" Value="True">
                                                                <Setter Property="MaxHeight" Value="72" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMessageExpanded}" Value="True">
                                                                <Setter Property="MaxHeight" Value="100000" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ItemsControl ItemsSource="{Binding Parts}"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Center"
                                                          Margin="{Binding DisplayMargin}"
                                                          ClipToBounds="False">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.TwitchEmote}">
                                                                        <Setter Property="Width" Value="{Binding DisplayWidth}" />
                                                                        <Setter Property="MinHeight" Value="{Binding DisplayHeight}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.ThirdPartyEmote}">
                                                                        <Setter Property="Width" Value="{Binding DisplayWidth}" />
                                                                        <Setter Property="MinHeight" Value="{Binding DisplayHeight}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <controls:AnimatedEmoteImage Width="{Binding DisplayWidth}"
                                                                                     Height="{Binding DisplayHeight}"
                                                                                     Media="{Binding Media}"
                                                                                     Stretch="Uniform"
                                                                                     Opacity="1"
                                                                                     ToolTip="{Binding ToolTip}"
                                                                                     Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                                                     RenderOptions.BitmapScalingMode="HighQuality" />
                                                        <ItemsControl ItemsSource="{Binding OverlayParts}"
                                                                      Width="{Binding DisplayWidth}"
                                                                      Height="{Binding DisplayHeight}"
                                                                      ClipToBounds="False"
                                                                      Panel.ZIndex="1"
                                                                      Visibility="{Binding HasOverlays, Converter={StaticResource BoolToVisibility}}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><Grid /></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <controls:AnimatedEmoteImage Width="{Binding DisplayWidth}"
                                                                                                 Height="{Binding DisplayHeight}"
                                                                                                 HorizontalAlignment="Center"
                                                                                                 VerticalAlignment="Center"
                                                                                                 Media="{Binding Media}"
                                                                                                 Stretch="Uniform"
                                                                                                 Opacity="1"
                                                                                                 ToolTip="{Binding ToolTip}"
                                                                                                 Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"
                                                                                                 RenderOptions.BitmapScalingMode="HighQuality" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="{Binding Text}"
                                                                   MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   Foreground="{DynamicResource PrimaryText}"
                                                                   Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibility}}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="TextDecorations" Value="{x:Null}" />
                                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.TwitchEmote}">
                                                                            <Setter Property="TextWrapping" Value="NoWrap" />
                                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                                            <Setter Property="ToolTip" Value="{Binding Text}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:ChatMessagePartKind.ThirdPartyEmote}">
                                                                            <Setter Property="TextWrapping" Value="NoWrap" />
                                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                                            <Setter Property="ToolTip" Value="{Binding Text}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding DataContext.IsModerated, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </StackPanel>
                                        <Border Background="{DynamicResource ButtonBackgroundBrush}"
                                                Grid.Column="4"
                                                CornerRadius="7"
                                                Padding="6,2"
                                                Margin="7,0,0,0"
                                                Visibility="{Binding IsModerated, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding ModerationStatus}"
                                                       Foreground="{DynamicResource MutedText}"
                                                       FontSize="10" />
                                        </Border>
                                    </Grid>
                                    </StackPanel>
                                </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid x:Name="JumpToLatestHost"
                          Grid.Row="1"
                          Width="50"
                          Height="54"
                          Margin="0,0,22,16"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Panel.ZIndex="10"
                          Opacity="0"
                          Visibility="Collapsed">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="8" />
                        </Grid.RenderTransform>
                        <Button x:Name="JumpToLatestButton"
                                Width="42"
                                Height="42"
                                MinHeight="42"
                                Padding="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Background="{DynamicResource ButtonBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushBright}"
                                Effect="{DynamicResource SoftShadow}"
                                Click="JumpToLatestButton_Click">
                            <Path Width="20"
                                  Height="20"
                                  Data="M4,7 L10,13 L16,7 M10,2 L10,13"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource PrimaryText}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Button>
                        <Border x:Name="UnreadMessagesBadge"
                                MinWidth="20"
                                Height="20"
                                Padding="5,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                CornerRadius="10"
                                Background="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource AppBackground}"
                                BorderThickness="2"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <TextBlock x:Name="UnreadMessagesText"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource SubtleGlassCardStyle}"
                            Grid.Row="1"
                            Padding="24"
                            MaxWidth="580"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding ShowChatEmptyState, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{Binding ChatEmptyTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding ChatEmptyText}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,9,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SubtleGlassCardStyle}"
                            Grid.Row="1"
                            Padding="28"
                            MaxWidth="560"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasActiveChannel, Converter={StaticResource InverseBoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource AppName}"
                                       Style="{StaticResource WindowTitleTextStyle}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{DynamicResource SignInHelp}"
                                       Foreground="{DynamicResource SecondaryText}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10,0,22" />
                            <Button Content="{DynamicResource ConnectTwitch}"
                                    Command="{Binding ConnectCommand}"
                                    Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                    MinWidth="210"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding ShowConnectButton, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="{DynamicResource CancelSignIn}"
                                    Command="{Binding CancelSignInCommand}"
                                    Style="{StaticResource PrimaryCapsuleButtonStyle}"
                                    MinWidth="210"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding ShowCancelSignInButton, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ToggleButton x:Name="ComposerPanelToggle"
                          Grid.Row="5"
                          IsChecked="True"
                          Margin="0,2"
                          Checked="ComposerPanelToggle_Checked"
                          Unchecked="ComposerPanelToggle_Unchecked"
                          Style="{StaticResource PanelVisibilityToggleStyle}"
                          Visibility="{Binding HasActiveChannel, Converter={StaticResource BoolToVisibility}}">
                <Grid Width="16" Height="10">
                    <Path Data="M2,2 L8,8 L14,2"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="ComposerPanelChevronRotation" />
                        </Path.RenderTransform>
                    </Path>
                </Grid>
            </ToggleButton>

            <Grid x:Name="ComposerPanel" Grid.Row="6">
            <Border
                    Style="{StaticResource SubtleGlassCardStyle}"
                    Padding="8"
                    Visibility="{Binding ShowMessageComposer, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageInput"
                             Grid.Row="0"
                             Grid.Column="0"
                             MinHeight="38"
                             MaxHeight="92"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding OutgoingMessage, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="MessageInput_PreviewKeyDown"
                             ToolTip="{DynamicResource EnterSendTooltip}"
                             Style="{StaticResource InputMessageTextBoxStyle}">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ChatScrollBarStyle}" />
                        </TextBox.Resources>
                    </TextBox>

                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="{DynamicResource Send}"
                            MinWidth="112"
                            Command="{Binding SendMessageCommand}"
                            ToolTip="{Binding SendButtonToolTip}"
                            ToolTipService.ShowOnDisabled="True"
                            Style="{StaticResource PrimaryCapsuleButtonStyle}"
                            Margin="8,0,0,0" />

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="8,7,8,1"
                            Padding="10,6"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource DangerBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource PanelAltBackground}"
                            Visibility="{Binding HasSendRestriction, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="13"
                                       Foreground="{DynamicResource DangerBrush}"
                                       Margin="0,0,7,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SendRestrictionText}"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border
                    Style="{StaticResource SubtleGlassCardStyle}"
                    Padding="14"
                    Visibility="{Binding ShowReadOnlyComposerNotice, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ReadOnlyComposerText}"
                           Foreground="{DynamicResource MutedText}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
            </Border>
            </Grid>
        </Grid>

        <Border x:Name="ChannelSwitcherDismissLayer"
                Panel.ZIndex="29"
                Background="Transparent"
                Visibility="Collapsed"
                MouseDown="ChannelSwitcherDismiss_MouseDown" />

        <Border x:Name="ChannelSwitcherFlyout"
                Panel.ZIndex="30"
                Width="330"
                MaxHeight="460"
                Margin="16,76,0,0"
                Padding="14"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Style="{StaticResource GlassCardStyle}"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0.5,0"
                KeyboardNavigation.TabNavigation="Cycle">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ChannelSwitcherScale" ScaleX="0.97" ScaleY="0.97" />
                    <TranslateTransform x:Name="ChannelSwitcherTranslate" Y="-8" />
                </TransformGroup>
            </Border.RenderTransform>
            <StackPanel>
                <TextBlock Text="{DynamicResource Channels}"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Margin="2,0,0,10" />
                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="7">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}" BasedOn="{StaticResource SubtleGlassCardStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="Background" Value="{DynamicResource GlassRowHoverBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding DataContext.SwitchChannelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="34" Height="34">
                                                <Ellipse Visibility="{Binding HasProfileImage, Converter={StaticResource BoolToVisibility}}">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding ProfileImageUrl}" Stretch="UniformToFill" />
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <Border CornerRadius="17"
                                                        Background="{DynamicResource ButtonBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                                        BorderThickness="1"
                                                        Visibility="{Binding HasProfileImage, Converter={StaticResource InverseBoolToVisibility}}">
                                                    <TextBlock Text="{Binding AvatarInitial}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="9,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ChannelLogin, StringFormat=@{0}}"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding ConnectionStatus}"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           FontSize="10"
                                                           Margin="0,3,0,0"
                                                           Visibility="{Binding ShowConnectionStatus, Converter={StaticResource BoolToVisibility}}" />
                                                <WrapPanel Margin="0,1,0,0">
                                                    <Border Background="{DynamicResource ButtonBackgroundBrush}"
                                                            CornerRadius="7"
                                                            Padding="6,2"
                                                            Margin="0,4,6,0"
                                                            Visibility="{Binding IsPrimaryAccountChannel, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{DynamicResource MyChannel}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Background="{DynamicResource ButtonBackgroundBrush}"
                                                            CornerRadius="7"
                                                            Padding="6,2"
                                                            Margin="0,4,6,0"
                                                            ToolTip="{Binding ModerationStatus}"
                                                            Visibility="{Binding IsModerator, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="{DynamicResource ModeratorRole}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource StreamLive}"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,7,0"
                                                           Visibility="{Binding IsLive, Converter={StaticResource BoolToVisibility}}" />
                                                <Border Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="9"
                                                        Padding="6,2"
                                                        Margin="0,0,7,0"
                                                        Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding UnreadCount}"
                                                               Foreground="{DynamicResource PrimaryButtonTextBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Ellipse Width="7"
                                                         Height="7"
                                                         Fill="{DynamicResource SuccessBrush}"
                                                         VerticalAlignment="Center"
                                                         ToolTip="{Binding ConnectionStatus}"
                                                         Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Command="{Binding DataContext.RemoveChannelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="{DynamicResource RemoveChannel}"
                                            Width="34"
                                            Height="34"
                                            MinHeight="34"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Margin="6,0,1,0"
                                            Visibility="{Binding CanRemove, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="{DynamicResource AddChannel}"
                        Command="{Binding AddChannelCommand}"
                        IsEnabled="{Binding CanAddChannel}"
                        Style="{StaticResource PrimaryCapsuleButtonStyle}"
                        Margin="0,4,0,0" />
                <TextBlock Text="{DynamicResource ChannelLimitHint}"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="2,8,2,0"
                           Visibility="{Binding CanAddChannel, Converter={StaticResource InverseBoolToVisibility}}" />
            </StackPanel>
        </Border>

        <Grid x:Name="OverlayHost"
              Visibility="Collapsed"
              Panel.ZIndex="100">
            <Border x:Name="OverlayScrim"
                    Background="#CC000000"
                    Opacity="0"
                    MouseDown="OverlayScrim_MouseDown" />
            <Border x:Name="OverlayPanelChrome"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="18"
                    MaxWidth="940"
                    Opacity="0">
                <ContentControl x:Name="OverlayContent" />
            </Border>
        </Grid>

        <Grid x:Name="DialogOverlayHost"
              Visibility="Collapsed"
              Panel.ZIndex="200">
            <Border x:Name="DialogScrim"
                    Background="#B3000000"
                    Opacity="0" />
            <Border x:Name="DialogCard"
                    Style="{StaticResource GlassCardStyle}"
                    Width="460"
                    MaxWidth="520"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0">
                <StackPanel>
                    <TextBlock x:Name="DialogTitleText"
                               Style="{StaticResource SectionTitleTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DialogMessageText"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,12,0,20"
                               TextWrapping="Wrap" />
                    <WrapPanel HorizontalAlignment="Right">
                        <Button x:Name="DialogCancelButton"
                                Content="{DynamicResource Cancel}"
                                Click="DialogCancel_Click"
                                Margin="0,0,8,0" />
                        <Button x:Name="DialogOkButton"
                                Content="OK"
                                Click="DialogOk_Click"
                                Style="{StaticResource PrimaryCapsuleButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Text="{DynamicResource VersionLine}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,24,4"
                   Foreground="{DynamicResource MutedText}"
                   FontSize="11"
                   Panel.ZIndex="5" />
    </Grid>
</Window>
